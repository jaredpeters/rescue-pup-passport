# Copy this file to `.env.local` and fill in your own Supabase values.
# DO NOT commit `.env.local` — it's already in .gitignore.
#
# To get these two values:
#   1. Create a free account at https://supabase.com
#   2. Create a new project (any name, any region near you)
#   3. In the sidebar: Settings (gear icon) -> API
#   4. Copy "Project URL" and "anon public" into the lines below.
#
# The anon key is SAFE to put in the browser — that's what it's designed for.
# Do NOT use the "service_role" key here — that one is secret.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
